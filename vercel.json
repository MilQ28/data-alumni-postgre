{
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.6.0" },
    { "src": "style/**", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "uploads/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/style/(.*)", "dest": "/style/$1" },
    { "src": "/uploads/(.*)", "dest": "/uploads/$1" },
    { "src": "/", "dest": "/login.php" },
    { "src": "/(.*)\\.php", "dest": "/$1.php" }
  ]
}
